---
import Icon from './Icon.astro';
interface Props {
  lang: 'en' | 'es';
  heading: string;
  subheading: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const { heading, subheading, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="section cta">
  <div class="container cta__inner">
    <h2>{heading}</h2>
    <p>{subheading}</p>
    <div class="cluster cta__actions">
      <a href={primaryHref} class="btn btn--accent">
        <Icon name="download" size={18} />
        {primaryLabel}
      </a>
      {
        secondaryLabel && secondaryHref && (
          <a href={secondaryHref} class="btn btn--outline">
            {secondaryLabel}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--color-primary-800);
    border-radius: var(--radius-lg);
    margin-inline: var(--space-5);
  }
  .cta__inner {
    text-align: center;
    max-width: 640px;
  }
  .cta h2 {
    color: #fff;
  }
  .cta p {
    color: var(--color-primary-100);
    font-size: var(--fs-md);
  }
  .cta__actions {
    justify-content: center;
    margin-top: var(--space-5);
  }
  /* The CTA panel is always a dark green surface (light or dark site theme),
     so its outline button needs its own always-light styling rather than
     the default .btn--outline, which assumes a light page behind it. */
  .cta :global(.btn--outline) {
    border-color: rgba(255, 255, 255, 0.55);
    color: #fff;
  }
  .cta :global(.btn--outline:hover) {
    background: rgba(255, 255, 255, 0.12);
  }
</style>
