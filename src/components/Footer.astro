---
import Icon from './Icon.astro';
import { NAV_LABELS } from '../lib/nav.js';

interface Props {
  lang: 'en' | 'es';
  slug: string;
}
const { lang, slug } = Astro.props;
const base = import.meta.env.BASE_URL;
const otherLang = lang === 'en' ? 'es' : 'en';
const p = (l: string, s: string) => `${base}${l}/${s ? s + '/' : ''}`;
const labels = NAV_LABELS[lang];
const year = new Date().getFullYear();

const copy = {
  en: {
    tagline: 'Run your landscaping business from your phone — no login, no cloud, no internet required.',
    supportEmail: 'support@canterapro.app',
    rights: `© ${year} CanteraPro. All rights reserved.`,
  },
  es: {
    tagline: 'Administra tu negocio de jardinería desde tu teléfono — sin inicio de sesión, sin nube, sin necesidad de internet.',
    supportEmail: 'support@canterapro.app',
    rights: `© ${year} CanteraPro. Todos los derechos reservados.`,
  },
};
const t = copy[lang];
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a href={p(lang, '')} class="brand">
          <Icon name="leaf" size={22} />
          <span>CanteraPro</span>
        </a>
        <p>{t.tagline}</p>
        <a href={`mailto:${t.supportEmail}`} class="cluster">
          <Icon name="mail" size={16} />
          {t.supportEmail}
        </a>
      </div>

      <div class="site-footer__col">
        <h2>{lang === 'en' ? 'Site' : 'Sitio'}</h2>
        <ul>
          <li><a href={p(lang, 'features')}>{labels.features}</a></li>
          <li><a href={p(lang, 'pricing')}>{labels.pricing}</a></li>
          <li><a href={p(lang, 'how-it-works')}>{labels['how-it-works']}</a></li>
          <li><a href={p(lang, 'about')}>{labels.about}</a></li>
          <li><a href={p(lang, 'download')}>{labels.download}</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h2>{lang === 'en' ? 'Legal' : 'Legal'}</h2>
        <ul>
          <li><a href={p(lang, 'privacy')}>{labels.privacy}</a></li>
          <li><a href={p(lang, 'terms')}>{labels.terms}</a></li>
          <li><a href={p(lang, 'support')}>{labels.support}</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h2>{lang === 'en' ? 'Language' : 'Idioma'}</h2>
        <ul>
          <li>
            <a href={p(otherLang, slug)} hreflang={otherLang}>
              <Icon name="languages" size={16} />
              {otherLang === 'en' ? 'English' : 'Español'}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>{t.rights}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-primary-900);
    color: var(--color-primary-100);
    margin-top: var(--space-9);
    padding-block: var(--space-8) var(--space-6);
  }
  .site-footer a {
    color: var(--color-primary-100);
  }
  .site-footer .brand {
    color: #fff;
  }
  .site-footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-6);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }
  .site-footer__brand p {
    color: var(--color-primary-100);
    opacity: 0.85;
    margin-block: var(--space-3);
    max-width: 32ch;
  }
  .site-footer__brand .cluster {
    text-decoration: none;
  }
  .site-footer h2 {
    color: #fff;
    font-family: var(--font-sans);
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-3);
  }
  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .site-footer ul a {
    opacity: 0.9;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }
  .site-footer ul a:hover {
    opacity: 1;
    text-decoration: underline;
  }
  .site-footer__bottom {
    padding-top: var(--space-5);
    font-size: var(--fs-xs);
    opacity: 0.75;
  }
  .site-footer__bottom p {
    margin: 0;
  }

  @media (max-width: 760px) {
    .site-footer__top {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .site-footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>
