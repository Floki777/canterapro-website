---
import Icon from './Icon.astro';
import FlagMX from './FlagMX.astro';
import { NAV_LABELS, PRIMARY_NAV_SLUGS } from '../lib/nav.js';

interface Props {
  lang: 'en' | 'es';
  slug: string;
}
const { lang, slug } = Astro.props;
const base = import.meta.env.BASE_URL;
const otherLang = lang === 'en' ? 'es' : 'en';
const p = (l: string, s: string) => `${base}${l}/${s ? s + '/' : ''}`;
const labels = NAV_LABELS[lang];
---

<header class="site-header">
  <div class="container site-header__bar">
    <a href={p(lang, '')} class="brand">
      <img src={`${base}icon.png`} alt="" width="32" height="32" class="brand-icon" />
      <span>Cantera<span class="brand-accent">Pro</span></span>
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" />
    <label for="nav-toggle" class="nav-toggle-label" aria-label="Menu">
      <Icon name="menu" size={22} />
    </label>

    <nav class="site-nav" aria-label={lang === 'en' ? 'Primary' : 'Principal'}>
      {
        PRIMARY_NAV_SLUGS.map((s) => (
          <a href={p(lang, s)} aria-current={s === slug ? 'page' : undefined}>
            {labels[s]}
          </a>
        ))
      }
      <a href={p(lang, 'download')} class="btn btn--primary btn--sm site-nav__cta">
        <Icon name="download" size={16} />
        {lang === 'en' ? 'Get the App' : 'Obtener la App'}
      </a>
      <a href={p(otherLang, slug)} class="lang-switch" hreflang={otherLang}>
        {otherLang === 'es' ? <FlagMX size={18} /> : <Icon name="languages" size={16} />}
        {otherLang === 'en' ? 'English' : 'Español'}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-0);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .site-header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-3);
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .brand-icon {
    border-radius: 50%;
    flex-shrink: 0;
  }
  .brand-accent {
    color: var(--color-accent-500);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-md);
    color: var(--color-primary-800);
    text-decoration: none !important;
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .site-nav a {
    color: var(--color-ink-700);
    font-weight: 600;
    font-size: var(--fs-sm);
    text-decoration: none !important;
  }
  .site-nav a:hover {
    color: var(--color-primary-700);
  }
  .site-nav a[aria-current='page'] {
    color: var(--color-primary-700);
    border-bottom: 2px solid var(--color-accent-500);
  }
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35em 0.9em !important;
  }
  .site-nav__cta {
    text-decoration: none !important;
  }
  .nav-toggle,
  .nav-toggle-label {
    display: none;
  }

  @media (max-width: 860px) {
    .nav-toggle-label {
      display: inline-flex;
      cursor: pointer;
      color: var(--color-primary-800);
    }
    .site-nav {
      display: none;
      width: 100%;
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-4);
      padding-block: var(--space-4);
      border-top: 1px solid var(--color-border);
    }
    .nav-toggle:checked ~ .site-nav {
      display: flex;
    }
  }

  @media (prefers-color-scheme: dark) {
    .brand {
      color: var(--color-primary-100);
    }
    .site-nav a:hover,
    .site-nav a[aria-current='page'] {
      color: var(--color-primary-400);
    }
    .nav-toggle-label {
      color: var(--color-primary-100);
    }
  }
</style>
