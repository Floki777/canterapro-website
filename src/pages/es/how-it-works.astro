---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import CTASection from '../../components/CTASection.astro';

const base = import.meta.env.BASE_URL;

const steps = [
  {
    icon: 'smartphone',
    title: '1. Descarga y abre la app — eso es todo',
    body: `No hay pantalla de registro. Nada de correo, contraseña, ni un paso de "crear cuenta".
    Instala CanteraPro desde App Store o Google Play, ábrela, y ya estás dentro de la app.
    Funciona igual con señal completa, una sola barra, o en modo avión.`,
  },
  {
    icon: 'languages',
    title: '2. Configura tu idioma',
    body: `Ve a Configuración del Negocio y toca el interruptor de idioma para cambiar toda la
    app — cada pantalla, cada formulario, cada PDF que generes — entre inglés y español. Puedes
    cambiar de uno a otro cuantas veces quieras, gratis, para siempre.`,
  },
  {
    icon: 'users',
    title: '3. Agrega tu primer cliente',
    body: `Abre la pestaña de Clientes y toca el botón de agregar. Escribe su nombre, teléfono,
    correo electrónico y dirección de la propiedad. Una vez guardado, el perfil de este cliente
    reunirá automáticamente cada trabajo, cotización y factura que crees para él — nunca más
    tendrás que buscar su historial.`,
  },
  {
    icon: 'clipboard-list',
    title: '4. Crea un trabajo',
    body: `Desde el perfil de un cliente, toca "Nuevo Trabajo." Dale un estado, agrega notas
    sobre el trabajo y toma fotos de antes si te sirve. Mientras trabajas, agrega fotos de
    durante y después, y registra los materiales que usaste — esto se vuelve parte del registro
    permanente de ese trabajo.`,
  },
  {
    icon: 'file-text',
    title: '5. Crea y envía una cotización',
    body: `Desde el perfil de un cliente, toca "Nueva Cotización" y agrega partidas de mano de
    obra y materiales. Aplica impuesto o descuento si es necesario. Toca "Exportar PDF" para
    generar una cotización de aspecto profesional, y envíala directamente a tu cliente por
    correo o mensaje de texto desde la misma pantalla.`,
  },
  {
    icon: 'receipt',
    title: '6. Convierte una cotización aceptada en factura',
    body: `Una vez que tu cliente te diga que sí, abre esa cotización y toca "Convertir a
    Factura." Cada partida se transfiere automáticamente — sin volver a escribir nada. Cuando
    termine el trabajo, entrégale tu teléfono a tu cliente para que firme, y luego exporta y
    envía la factura en PDF terminada.`,
  },
  {
    icon: 'calendar-days',
    title: '7. Planea tu día con el Horario',
    body: `Abre la pestaña de Horario para ver todos tus trabajos organizados por día. Si tienes
    más de una parada, toca "Optimizar Ruta" y CanteraPro te sugerirá el orden más eficiente
    para visitarlas, ahorrándote tiempo de manejo entre trabajos.`,
  },
  {
    icon: 'clock',
    title: '8. Marca tu entrada y salida',
    body: `Desde la pantalla de un trabajo, toca "Marcar Entrada" cuando llegues y "Marcar
    Salida" cuando te vayas. Agrega una nota rápida si algo afectó tu tiempo — una ida a comprar
    material, una conversación con el cliente, lo que sea. Tus horas se guardan automáticamente
    por trabajo.`,
  },
  {
    icon: 'repeat',
    title: '9. Configura una cuenta de mantenimiento recurrente',
    body: `Para los clientes a quienes das servicio en un horario fijo — corte semanal, poda
    quincenal, mantenimiento mensual — abre su perfil y toca "Agregar Cuenta de Mantenimiento."
    Elige la frecuencia y CanteraPro marcará automáticamente la cuenta cuando esté atrasada para
    su próxima visita.`,
  },
  {
    icon: 'spray-can',
    title: '10. Registra una aplicación de producto',
    body: `Abre una propiedad y toca "Registrar Aplicación" en Aplicaciones de Productos. Anota
    qué se aplicó y cuándo. CanteraPro da seguimiento automático a la fecha de la próxima
    aplicación, para que siempre sepas cuándo le toca a una propiedad su siguiente tratamiento.`,
  },
  {
    icon: 'calculator',
    title: '11. Usa la Calculadora de Materiales',
    body: `Abre la Calculadora de Materiales, elige tu material — mantillo, tierra vegetal,
    grava, granito decompuesto, arena, roca volcánica, roca de río o concreto triturado — e
    ingresa las dimensiones de tu área. CanteraPro calcula las yardas cúbicas que necesitas,
    agrega un margen de desperdicio del 10% y te da un estimado de costo.`,
  },
  {
    icon: 'route',
    title: '12. Revisa tu Registro de Millaje',
    body: `CanteraPro registra automáticamente en segundo plano las millas de negocio que
    manejas entre trabajos. Abre el Registro de Millaje cuando quieras para ver tu total mensual
    de forma gratuita. En Pro, toca "Exportar PDF Fiscal" para un reporte listo para presentar,
    con las tarifas de millaje del IRS ya calculadas.`,
  },
  {
    icon: 'shield-check',
    title: '13. Respalda tus datos',
    body: `Abre Configuración del Negocio y toca "Respaldar Ahora." Elige una contraseña para
    encriptar el archivo de respaldo, y guárdalo donde quieras — tu app de Archivos, Google
    Drive, o envíatelo por correo. Si algún día consigues un teléfono nuevo, instala CanteraPro,
    toca "Restaurar desde Respaldo," elige tu archivo e ingresa tu contraseña para recuperar todo
    exactamente como estaba.`,
  },
];
---

<BaseLayout
  lang="es"
  slug="how-it-works"
  title="Cómo Funciona"
  description="Una guía paso a paso para usar CanteraPro — desde abrir la app por primera vez hasta respaldar tus datos, sin necesidad de experiencia previa con apps de negocios."
>
  <section class="section page-hero">
    <div class="container">
      <span class="eyebrow">Cómo Funciona</span>
      <h1>Una guía en lenguaje sencillo, aunque nunca hayas usado una app de negocios.</h1>
      <p class="page-hero__lede">
        Sin tecnicismos, sin suposiciones. Sigue estos pasos en orden la primera vez que uses la
        app, o ve directo a la función con la que necesites ayuda.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ol class="howto-list">
        {
          steps.map((step) => (
            <li class="howto-step card">
              <div class="feature-icon">
                <Icon name={step.icon} size={26} />
              </div>
              <h2>{step.title}</h2>
              <p>{step.body}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <CTASection
    lang="es"
    heading="¿Todavía tienes una pregunta?"
    subheading="Revisa las preguntas frecuentes, o contáctanos directamente — leemos cada mensaje."
    primaryLabel="Descargar Ahora"
    primaryHref={`${base}es/download/`}
    secondaryLabel="Visitar Soporte"
    secondaryHref={`${base}es/support/`}
  />
</BaseLayout>

<style>
  .page-hero {
    padding-top: var(--space-8);
    padding-bottom: var(--space-4);
  }
  .page-hero__lede {
    max-width: 60ch;
    font-size: var(--fs-md);
    color: var(--color-ink-700);
  }
  .howto-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .howto-step h2 {
    font-size: var(--fs-lg);
  }
</style>
