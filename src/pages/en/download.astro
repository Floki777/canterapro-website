---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  lang="en"
  slug="download"
  title="Coming Soon"
  description="CanteraPro is in review with the Apple App Store and about to enter closed testing on Google Play. Download links will appear here the moment it's live."
>
  <section class="section page-hero">
    <div class="container download-hero">
      <span class="eyebrow">Coming Soon</span>
      <h1>CanteraPro is almost here.</h1>
      <p class="page-hero__lede">
        We've submitted CanteraPro to the Apple App Store for review, and we're about to open
        closed testing on Google Play. The real download links will appear right here the moment
        it's approved — no waitlist signup needed, just check back.
      </p>

      <div class="store-badges">
        <!--
          Once the app is approved in each store, replace these two <span> placeholders with
          real <a href="..."> links to your store listings (and, ideally, the official Apple/
          Google badge assets). Official badges:
          Apple: https://developer.apple.com/app-store/marketing/guidelines/#section-badges
          Google: https://play.google.com/intl/en_us/badges/
        -->
        <span class="store-badge store-badge--pending" aria-label="Coming soon to the App Store">
          <Icon name="apple-logo" size={22} />
          <span>
            <small>Coming soon to the</small>
            App Store
          </span>
        </span>
        <span class="store-badge store-badge--pending" aria-label="Coming soon to Google Play">
          <Icon name="google-play" size={22} />
          <span>
            <small>Coming soon to</small>
            Google Play
          </span>
        </span>
      </div>

      <p class="notify-note">
        Want to know the moment it's live? <a href="mailto:tier1offgrid@protonmail.com?subject=Notify%20me%20when%20CanteraPro%20launches">Email us</a>
        and we'll let you know.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container next-steps">
      <h2>What to expect once it's live</h2>
      <ol>
        <li>Install CanteraPro from the App Store or Google Play.</li>
        <li>Open it — you'll land straight in the app, no sign-up screen.</li>
        <li>Set your language (English or Spanish) in Business Settings, if needed.</li>
        <li>Add your first client and you're off.</li>
      </ol>
      <p>
        Curious how it works in the meantime? The <a href={`${base}en/how-it-works/`}>How It Works</a>
        guide walks through every feature step by step.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-top: var(--space-8);
  }
  .download-hero {
    max-width: 640px;
    text-align: center;
    margin-inline: auto;
  }
  .page-hero__lede {
    font-size: var(--fs-md);
    color: var(--color-ink-700);
  }
  .store-badges {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-6);
  }
  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--color-primary-900);
    color: #fff !important;
    padding: 0.85em 1.5em;
    border-radius: var(--radius-md);
    text-decoration: none !important;
    text-align: left;
    font-weight: 700;
  }
  .store-badge small {
    display: block;
    font-weight: 400;
    font-size: var(--fs-xs);
    opacity: 0.8;
  }
  .store-badge--pending {
    /* Fixed (non-theme-flipping) muted tone — this badge is intentionally
       "disabled"-looking in both light and dark mode. */
    background: #647069;
    cursor: default;
  }
  .notify-note {
    margin-top: var(--space-5);
    font-size: var(--fs-sm);
    color: var(--color-ink-500);
  }
  .next-steps {
    max-width: 640px;
    margin-inline: auto;
    text-align: center;
  }
  .next-steps ol {
    text-align: left;
    display: inline-block;
  }
</style>
